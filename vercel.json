{
  "version": 2,
  "builds": [
    { "src": "api/chat.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "methods": ["POST"], "dest": "/api/chat.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.+)", "dest": "/public/$1" }
  ]
}
